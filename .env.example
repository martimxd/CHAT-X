# Application
NODE_ENV=production
APP_NAME=Chat X
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3000
# Leave VITE_API_BASE_URL empty when the web app and API are served from the same origin.
VITE_API_BASE_URL=
WEB_PORT=3000
API_PORT=4000
TRUST_PROXY=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_CLOUDFLARE_TEMP_TUNNELS=false
COOKIE_SECURE_AUTO=true
COOKIE_SAMESITE=lax
# Legacy names are still accepted for older deployments:
# PUBLIC_APP_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000

# Database
POSTGRES_DB=chat_x
POSTGRES_USER=chat_x
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgres://chat_x:change-this-database-password@db:5432/chat_x

# Authentication
SESSION_TTL_HOURS=168
BCRYPT_COST=12
LOGIN_RATE_LIMIT_MAX=8
REGISTER_RATE_LIMIT_MAX=8
MESSAGE_RATE_LIMIT_MAX=120
QR_LOGIN_TTL_SECONDS=120

# Media
MEDIA_ROOT=/app/media
MEDIA_SIGNING_SECRET=replace-with-at-least-32-random-bytes
# Base64-encoded 32-byte key. Generate with: openssl rand -base64 32
MEDIA_ENCRYPTION_KEY_BASE64=replace-with-base64-32-byte-key
MAX_UPLOAD_BYTES=52428800
SIGNED_MEDIA_URL_TTL_SECONDS=300
VIDEO_COMPRESSION_CRF=28
# Disabled by default because server-side media compression requires the server to see plaintext before encrypting at rest.
ALLOW_TRUSTED_MEDIA_PROCESSING=false

# WebRTC calls
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Cleanup
CLEANUP_INTERVAL_SECONDS=300
ORPHAN_MEDIA_RETENTION_HOURS=24

# Reverse proxy / production
HTTPS_ONLY=false
